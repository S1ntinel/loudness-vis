{
  "name": "loudness-vis",
  "version": "1.0.0",
  "private": true,
  "description": "Audio Visualization Workstation",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start:local": "node scripts/local-demo-server.mjs --build --open hub",
    "start:dist": "node scripts/local-demo-server.mjs --build --open dist",
    "start:lite": "node scripts/local-demo-server.mjs --open lite",
    "start:legacy": "node scripts/local-demo-server.mjs --open legacy",
    "lite:build": "node scripts/build-lite.mjs",
    "uv:sync": "node scripts/sync-uv-assets.mjs",
    "uv:build": "npm run build && npm run uv:sync && node scripts/build-uv.mjs",
    "dev:electron": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "build:exe": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.loudnessvis.app",
    "productName": "LoudnessVis",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "assets/icons/app.ico",
        "to": "icon.ico"
      },
      {
        "from": "electron/audio-session-helper.ps1",
        "to": "helpers/audio-session-helper.ps1"
      }
    ],
    "icon": "assets/icons/app.ico",
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "installerIcon": "assets/icons/app.ico",
      "uninstallerIcon": "assets/icons/app.ico",
      "installerHeaderIcon": "assets/icons/app.ico"
    }
  },
  "dependencies": {
    "i18next": "^26.1.0",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.0"
  }
}
